# Copy to .env and fill in. Never commit .env (already in .gitignore).
# Either provider works; you only need the keys for whichever you actually use.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: override default model selection from CLI / scripts.
# Real choice lives in simulations/<sim>/persona_configs/<config>.yaml.
# KAISIM_DEFAULT_PROVIDER=anthropic
# KAISIM_DEFAULT_MODEL=claude-sonnet-4-6
